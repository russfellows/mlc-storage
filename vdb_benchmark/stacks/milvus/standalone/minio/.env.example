# Copy this file to .env and fill in real values
# Do NOT commit .env to version control


# Optional
# ----------------------------
LOG_LEVEL=info


# MinIO configuration (Local Object Storage)
# -------------------------------------------------------------------
MINIO_IMAGE=minio/minio:RELEASE.2023-03-20T20-16-18Z
MINIO_CONTAINER_NAME=milvus-minio
MINIO_BUCKET_NAME=milvus-bucket

MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

MINIO_DATA_DIR=/mnt/vdb/minio


# ETCD configuration
# ----------------------------
ETCD_IMAGE=quay.io/coreos/etcd:v3.5.18
ETCD_CONTAINER_NAME=milvus-etcd

ETCD_CLIENT_PORT=2379
ETCD_DATA_DIR=/mnt/vdb/etcd

ETCD_AUTO_COMPACTION_MODE=revision
ETCD_AUTO_COMPACTION_RETENTION=1000
ETCD_QUOTA_BACKEND_BYTES=4294967296
ETCD_SNAPSHOT_COUNT=50000


# Milvus Standalone Configuration
# -------------------------------------------------------------------
MILVUS_IMAGE=milvusdb/milvus:v2.5.10
MILVUS_CONTAINER_NAME=milvus-standalone
MILVUS_GRPC_PORT=19530
MILVUS_HTTP_PORT=9091
MILVUS_DATA_DIR=/mnt/vdb/milvus

# Milvus ENV
MINIO_ADDRESS=minio:${MINIO_PORT}
MINIO_REGION=us-east-1
ETCD_ENDPOINTS=etcd:${ETCD_CLIENT_PORT}
