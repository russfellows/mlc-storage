# Copy this file to .env and fill in real values
# Do NOT commit .env to version control


# Optional
# ----------------------------
LOG_LEVEL=info


# Milvus Configuration
# ----------------------------
MILVUS_IMAGE=milvusdb/milvus:v2.5.10
MILVUS_CONTAINER_NAME=milvus-s3
MILVUS_GRPC_PORT=19530
MILVUS_HTTP_PORT=9091


# Milvus S3 Configuration
# ----------------------------
MINIO_ENDPOINT=https://s3.amazonaws.com
MINIO_REGION=us-east-1
MINIO_BUCKET_NAME=milvus-bucket
MINIO_ACCESS_KEY_ID=your-access-key
MINIO_SECRET_ACCESS_KEY=your-secret-key
MINIO_USE_SSL=false
MINIO_ROOT_PATH=milvus

